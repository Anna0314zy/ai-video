{
  "name": "ai-video",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ai-video/web dev",
    "dev:web": "pnpm --filter @ai-video/web dev",
    "dev:server": "pnpm --filter @ai-video/server dev",
    "build": "pnpm --filter @ai-video/web build:test && pnpm --filter @ai-video/server build",
    "build:web": "pnpm --filter @ai-video/web build:test",
    "build:server": "pnpm --filter @ai-video/server build",
    "test:server": "pnpm --filter @ai-video/server test",
    "lint:web": "pnpm --filter @ai-video/web lint",
    "preview": "pnpm --filter @ai-video/web preview",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "husky": "^8.0.3"
  }
}
