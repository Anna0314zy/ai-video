{
  "name": "ai-content-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build:test": "tsc -b && vite build --mode test",
    "build:prod": "tsc -b && vite build --mode prod",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prepare": "husky install",
    "hotUpdate:test": "node ./src/script/hotUpdate.cjs --mode test",
    "hotUpdate:prod": "node ./src/script/hotUpdate.cjs  --mode prod",
    "release:test": "pnpm install && pnpm run build:test && pnpm run hotUpdate:test",
    "release:prod": "pnpm install && pnpm run build:prod && pnpm run hotUpdate:prod"
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@ld/file-upload": "^1.0.26",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@rematch/core": "^2.2.0",
    "@rematch/immer": "^2.1.3",
    "@svgr/rollup": "^8.1.0",
    "ahooks": "^3.8.1",
    "antd": "^5.19.3",
    "axios": "^1.7.2",
    "classnames": "^2.5.1",
    "cos-nodejs-sdk-v5": "^2.14.4",
    "dayjs": "^1.11.12",
    "events": "^3.3.0",
    "immer": "^9.0.6",
    "localforage": "^1.10.0",
    "markdown-it": "^14.1.0",
    "minimist": "^1.2.8",
    "postcss-px-to-viewport": "^1.1.1",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.25.1",
    "redux": "^5.0.1",
    "sockjs": "^0.3.24",
    "sockjs-client": "^1.6.1",
    "spark-md5": "^3.0.2",
    "stompjs": "^2.3.3",
    "typed.js": "^2.1.0",
    "uuid": "^10.0.0",
    "v": "^0.3.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.4.0",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@types/events": "^3.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.0",
    "@types/sockjs-client": "^1.5.4",
    "@types/stompjs": "^2.3.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^8.0.3",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "lint-staged": "^15.2.7",
    "typescript": "^5.2.2",
    "vite": "^5.3.4"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint --config commitlint.config.cjs -E HUSKY_GIT_PARAMS"
    }
  }
}